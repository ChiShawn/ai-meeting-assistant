# Meeting App backend
VLLM_API_URL=http://127.0.0.1:18080/v1/chat/completions
VLLM_MODEL_NAME=Qwen/Qwen3-0.6B
REMOTE_ASR_URL=http://127.0.0.1:18080/asr
ALLOW_ORIGINS=*
REQUEST_TIMEOUT=10800
FRONTEND_DIR=frontend
LOG_LEVEL=INFO

# Local fallback Whisper
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_LOCAL_SIZE=small
FFMPEG_BIN=ffmpeg
AUDIO_CONVERT_BEFORE_ASR=1

# Optional SSH fallback. Prefer REMOTE_ASR_URL for production deployments.
H200_SSH_USER=
H200_SSH_HOST=
H200_SSH_JUMP=
H200_WHISPER_CONTAINER=
H200_WHISPER_URL=

# Remote GPU backend
LLM_MODEL_ID=Qwen/Qwen3-0.6B
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=float16
CORRECTION_DIR=./corrections
CORRECTION_FIXBOOK_FILES=
MEDICAL_TERMS_XLSX=
ENABLE_MEDICAL_TERMS=0

# Word report generation behavior
DOCX_USE_LLM_PLAN=1
DOCX_USE_LLM_CLASSIFY=0
DOCX_FALLBACK_MAX_LINES=18
DOCX_FALLBACK_MAX_CHARS=1200
SUMMARY_MAX_LINES=18
SUMMARY_MAX_CHARS=1600
